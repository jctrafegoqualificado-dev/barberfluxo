# Banco de dados (Neon PostgreSQL — neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT (qualquer string longa e aleatória)
JWT_SECRET="sua_chave_secreta_aqui_minimo_32_caracteres"

# URL do sistema (trocar para o domínio real no Vercel)
NEXTAUTH_URL="http://localhost:3000"

# Email — Resend (resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="BarberApp <noreply@seudominio.com.br>"

# Mercado Pago (mercadopago.com.br → Suas integrações → Credenciais)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"

# Secret para proteger os endpoints de cron job (mark-noshow, reminders, etc.)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="seu_cron_secret_aqui_minimo_32_caracteres"
