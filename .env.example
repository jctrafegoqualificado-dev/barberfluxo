# ============================================================
#  BarberFluxo — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com seus valores.
#  NUNCA commite o .env — ele está no .gitignore.
# ============================================================

# ── Banco de dados (Supabase / Neon PostgreSQL) ──────────────
# Use o Transaction Pooler (porta 6543) para compatibilidade com Serverless
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?connection_limit=5"

# ── JWT ──────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-minimo-64-chars"

# ── URL do sistema ───────────────────────────────────────────
NEXTAUTH_URL="https://seudominio.com.br"

# ── E-mail (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="BarberFluxo <noreply@seudominio.com.br>"

# ── Mercado Pago ─────────────────────────────────────────────
# TESTE (sandbox)
MERCADOPAGO_ACCESS_TOKEN="TEST-xxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# PRODUÇÃO (descomente quando for ao ar e comente as de TESTE acima)
# MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# MERCADOPAGO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxx"
# MERCADOPAGO_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Webhook secret — gerado no painel do MP em "Suas integrações > Webhooks"
# Usado para validar a assinatura HMAC de cada notificação recebida
MERCADOPAGO_WEBHOOK_SECRET="troque-pelo-secret-gerado-no-painel-do-mp"

# ── WhatsApp — Evolution API ─────────────────────────────────
EVOLUTION_API_URL="https://sua-api-evolution.com.br"
EVOLUTION_SERVER_URL="https://sua-api-evolution.com.br"
EVOLUTION_GLOBAL_API_KEY="troque-pela-sua-chave-global"
EVOLUTION_API_KEY="troque-pela-sua-chave-de-instancia"
EVOLUTION_INSTANCE_NAME="nome-da-sua-instancia"

# ── N8N — Assistente IA via Evolution ────────────────────────
# URL do webhook do workflow genérico no N8N.
# Toda nova barbearia que conectar o WhatsApp aponta automaticamente para cá.
N8N_EVOLUTION_WEBHOOK_URL="https://n8n.iadebarbearia.com.br/webhook/evolution-webhook"

# ── API Pública (n8n, webhooks externos) ─────────────────────
# Gere com: openssl rand -base64 36
PUBLIC_API_KEY="troque-por-chave-aleatoria-longa"

# ── Cron Jobs ────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
CRON_SECRET="troque-por-string-aleatoria-para-proteger-os-crons"

# ── Upstash Redis (rate limiting) ────────────────────────────
UPSTASH_REDIS_REST_URL="https://sua-instancia.upstash.io"
UPSTASH_REDIS_REST_TOKEN="troque-pelo-seu-token-upstash"

# ── Sentry (monitoramento de erros) ──────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
SENTRY_ORG="sua-org"
SENTRY_PROJECT="seu-projeto"
SENTRY_AUTH_TOKEN="sntryu_xxxxxxxxxxxxxxxxxxxx"
