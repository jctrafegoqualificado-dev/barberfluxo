generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Transaction Pooler port 6543
}

enum SaasPlan {
  BASIC
  PRO
  ELITE
  PREMIUM // Legacy — equivale a ELITE (manter para assinantes existentes)
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role              String   @default("CLIENT") // PLATFORM_ADMIN | OWNER | BARBER | CLIENT
  isPlatformAdmin   Boolean  @default(false)    // permite acesso ao /plataforma sem mudar o role
  isBlocked Boolean  @default(false)
  birthday  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedShop        Barbershop?       @relation("ShopOwner")
  barberProfile    Barber?
  appointments     Appointment[]     @relation("ClientAppointments")
  subscriptions    Subscription[]
  productSales     ProductSale[]     @relation("ClientProductSales")
  whatsappContacts WhatsAppContact[]
  reviews          Review[]          @relation("ClientReviews")
  loyaltyPoints    LoyaltyPoint[]    @relation("ClientLoyaltyPoints")
  clientRetentions ClientRetention[]
}

model Barbershop {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  phone       String?
  address     String?
  city        String?
  state       String?
  description String?
  instagram        String?
  cnpj             String?
  zipCode          String?
  neighborhood     String?
  streetNumber     String?
  streetComplement String?
  contactEmail     String?
  logoUrl     String?
  primaryColor String? @default("#f59e0b")
  secondaryColor String? @default("#fbbf24")
  favIconUrl   String?
  active      Boolean  @default(true)
  onboardingCompleted Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saasPlan    SaasPlan  @default(BASIC)
  trialEndsAt DateTime?
  saasStatus        String   @default("TRIAL")  // TRIAL | ACTIVE | OVERDUE | CANCELLED | PAUSED
  saasExpiresAt     DateTime?  // data de vencimento do plano pago (null = trial / sem data)
  mpSubscriptionId  String?  // MP preapproval ID (assinatura recorrente)

  poeOwnerPct     Float @default(50)
  debitFee        Float @default(0)
  creditFee       Float @default(0)
  poeDeductFees      Boolean @default(false)
  poeSubscriptionFee Float   @default(0)
  reminderMinutes Int     @default(60)
  reminderEnabled Boolean @default(false)
  reminderMessage String? // Template: "Olá {{nome}}, seu horário de {{servico}} é amanhã às {{hora}}!"

  cancelByClientEnabled Boolean @default(true)
  minCancelHours        Int     @default(0)

  // ── Assistente IA (N8N / Evolution) ─────────────────────────────────────────
  aiAssistantName     String?  @db.VarChar(50)  // Ex: "Barba Bot"
  aiPersonality       String?  @db.Text         // Texto livre → vai direto para o system prompt do LLM
  aiGreetingDirective String?  @db.Text         // Diretriz de como cumprimentar na primeira mensagem
  aiIdioma            String?  @db.VarChar(10)  // Ex: "pt-BR", "en-US", "es-ES"
  aiAtendimentoAtivo  Boolean  @default(true)   // Liga/desliga o assistente por completo
  aiMensagemBoasVindas             String?  @db.Text  // Mensagem literal enviada no primeiro contato
  aiMensagemAusencia               String?  @db.Text  // Fora do horário de atendimento
  aiMensagemConfirmacaoAgendamento String?  @db.Text  // Após confirmar agendamento
  aiMensagemCancelamento           String?  @db.Text  // Após cancelar agendamento
  aiObservacoesAdicionais          String?  @db.Text  // Instruções extras / regras adicionais

  autoNoShowEnabled Boolean @default(true)
  autoNoShowHours   Int     @default(24)

  // ── Retenção de Clientes ────────────────────────────────────────────────────
  retentionEnabled  Boolean @default(false)
  retentionDays     Int     @default(45)   // dias de inatividade para disparar
  retentionMessage  String? @db.Text       // template personalizado ({{nome}}, {{dias}}, {{empresa}})

  // Sistema de descontos na comanda
  discountServicesEnabled Boolean @default(false)
  discountServicesMax     Float   @default(20)   // teto máximo % que o barbeiro pode conceder em serviços
  discountProductsEnabled Boolean @default(false)
  discountProductsMax     Float   @default(20)   // teto máximo % que o barbeiro pode conceder em produtos

  ownerId String @unique
  owner   User   @relation("ShopOwner", fields: [ownerId], references: [id])

  barbers            Barber[]
  services           Service[]
  appointments       Appointment[]
  plans              Plan[]
  subscriptions      Subscription[]
  openingHours       OpeningHour[]
  specialDays        SpecialDay[]
  metas              Meta[]
  products           Product[]
  productSales       ProductSale[]
  tasks              Task[]
  commissionPayments CommissionPayment[]
  commissionVales    CommissionVale[]

  whatsappInstance WhatsAppInstance?
  whatsappContacts WhatsAppContact[]
  whatsappMessages WhatsAppMessage[]
  whatsappSessions WhatsAppSession[]
  saasPayments     Payment[]
  reviews          Review[]
  loyaltyPoints    LoyaltyPoint[]
  expenses         Expense[]
  cashFlowSessions CashFlowSession[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  paymentGateway   PaymentGatewayConfig?
  clientRetentions ClientRetention[]
}

model WhatsAppInstance {
  id                    String     @id @default(cuid())
  barbershopId          String     @unique
  barbershop            Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  evolutionInstanceName String     @unique
  evolutionToken        String
  status                String     @default("PENDING") // PENDING | CONNECTING | CONNECTED | DISCONNECTED | ERROR
  lastQrCode            String?    @db.Text
  lastConnectedAt       DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  contacts WhatsAppContact[]
  messages WhatsAppMessage[]

  @@index([evolutionInstanceName])
  @@index([status])
}

model Barber {
  id        String   @id @default(cuid())
  nickname  String?
  bio       String?
  photoUrl  String?
  cpf       String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  dayOff Int? // 0=Dom 1=Seg 2=Ter 3=Qua 4=Qui 5=Sex 6=Sáb — null = sem folga fixa

  // Comissão em serviços avulsos
  commissionType String @default("PERCENTAGE") // PERCENTAGE | FIXED
  commission     Float  @default(50) // % ou R$ dependendo do tipo

  // Comissão em produtos vendidos
  productCommissionType String @default("PERCENTAGE")
  productCommission     Float  @default(10)

  userId       String     @unique
  user         User       @relation(fields: [userId], references: [id])
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  appointments       Appointment[]
  scheduleBlocks     ScheduleBlock[]
  metas              Meta[]
  productSales       ProductSale[]
  tasks              Task[]
  commissionPayments CommissionPayment[]
  commissionVales    CommissionVale[]
  reviews            Review[]
  allowedPlans       Plan[] @relation("PlanAllowedBarbers")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  duration    Int // minutes
  imageUrl    String?
  commission  Float?
  materialCost Float   @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  appointments        Appointment[]
  planServices        PlanService[]
  appointmentServices AppointmentService[] @relation("AppointmentServices")
}

model Appointment {
  id            String   @id @default(cuid())
  date          DateTime
  startTime     String
  endTime       String
  status        String   @default("PENDING")
  paymentMethod      String?  @default("CASH")
  extraPrice         Float    @default(0)
  extraPaymentMethod String?
  discountPercent    Float    @default(0) // % de desconto aplicado na comanda (sobre price para avulsos, sobre extraPrice para assinantes)
  notes              String?
  price              Float
  reminderSent  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clientId       String
  client         User          @relation("ClientAppointments", fields: [clientId], references: [id])
  barbershopId   String
  barbershop     Barbershop    @relation(fields: [barbershopId], references: [id])
  barberId       String
  barber         Barber        @relation(fields: [barberId], references: [id])
  serviceId      String?
  service        Service?      @relation(fields: [serviceId], references: [id])
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  beneficiaryName String?

  services AppointmentService[]
  review   Review?

  // ── Link de pagamento MP avulso (Sprint MP) ─────────────────────────────────
  // Permite cobrar o cliente pelo WhatsApp antes de chegar na barbearia
  mpPaymentLink     String?   // init_point do MP para enviar ao cliente
  mpPreferenceId    String?   // ID da Preference no MP (para rastrear)
  mpPaymentId       String?   // ID do Payment confirmado no MP (idempotência)

  @@index([barbershopId, date])
  @@index([barbershopId, status, date])
  @@index([status])
  @@index([clientId])
  @@index([mpPaymentId]) // busca rápida no webhook de pagamento avulso
}

model AppointmentService {
  id            String @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation("AppointmentServices", fields: [serviceId], references: [id])
  price         Float
  duration      Int

  @@unique([appointmentId, serviceId])
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  description  String?
  price        Float
  billingCycle String   @default("MONTHLY") // MONTHLY | QUARTERLY | YEARLY
  maxUses      Int? // null = unlimited
  beneficiaryRules Json? // Regras para dependentes. Ex: [{ name: "Titular", maxUses: 4 }, { name: "Filho", maxUses: 2 }]
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  barbershopId  String
  barbershop    Barbershop     @relation(fields: [barbershopId], references: [id])
  planServices  PlanService[]
  subscriptions Subscription[]
  commissionPercentage Float? // Comissão especial (%) para os serviços realizados dentro deste plano
  extraDiscount        Float  @default(0) // % de desconto automático nos serviços extras para assinantes deste plano (0 = sem desconto)
  allowedBarbers Barber[] @relation("PlanAllowedBarbers")
}

model PlanService {
  id        String  @id @default(cuid())
  planId    String
  plan      Plan    @relation(fields: [planId], references: [id])
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  quantity  Int?    // null = ilimitado, number = máx. usos por ciclo
}

model Subscription {
  id              String   @id @default(cuid())
  status          String   @default("ACTIVE") // ACTIVE | CANCELLED | OVERDUE | PAUSED
  startDate       DateTime @default(now())
  nextBillingDate DateTime
  billingDay      Int?     // 1-31: dia fixo de vencimento; null = sem fixação
  usesThisCycle   Int      @default(0)
  beneficiaries   Json?    // Controle de uso por beneficiário. Ex: [{ name: "João (Pai)", uses: 0, maxUses: 4 }, { name: "Pedrinho (Filho)", uses: 0, maxUses: 2 }]
  mpPreapprovalId String?  // MP Preapproval ID — débito recorrente autorizado pelo cliente

  // ── Gateway de pagamento por barbearia (Sprint MP) ──────────────────────────
  // MANUAL           = sem gateway configurado; dono dá baixa manualmente
  // PENDING_AUTH     = preapproval criado; aguardando cliente clicar no link
  // AUTHORIZED       = cliente autorizou; MP cobra automaticamente
  // FAILED           = falha na autorização ou cobrança recorrente
  authorizationStatus String    @default("MANUAL")
  authorizationLink   String?   // init_point enviado ao cliente
  authorizationSentAt DateTime? // última vez que o link foi enviado

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientId     String
  client       User          @relation(fields: [clientId], references: [id])
  barbershopId String
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  planId       String
  plan         Plan          @relation(fields: [planId], references: [id])
  payments     Payment[]
  appointments Appointment[]
}

model Payment {
  id         String    @id @default(cuid())
  amount     Float
  method     String // PIX | CREDIT_CARD | CASH | DEBIT_CARD
  status     String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  externalId String?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())

  // ── Gateway de pagamento (Sprint MP) ────────────────────────────────────────
  mpPaymentId  String?   // ID do authorized_payment no MP (para idempotência no webhook)
  gatewayType  String?   // "mercadopago" | null (manual)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  barbershopId   String?
  barbershop     Barbershop?   @relation(fields: [barbershopId], references: [id])

  @@index([mpPaymentId]) // busca rápida por ID do MP no webhook
}

model OpeningHour {
  id        String  @id @default(cuid())
  dayOfWeek Int // 0=Sunday ... 6=Saturday
  openTime  String // "09:00"
  closeTime String // "20:00"
  isOpen    Boolean @default(true)

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  @@unique([barbershopId, dayOfWeek])
}

model SpecialDay {
  id        String  @id @default(cuid())
  date      String  // "2025-12-25"
  isClosed  Boolean @default(true)
  openTime  String? // null se isClosed
  closeTime String? // null se isClosed
  reason    String?

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  @@unique([barbershopId, date])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  costPrice   Float    @default(0)
  stock       Int      @default(0)
  barcode     String?  // Removed @unique to prevent conflicts if multiple nulls or empty strings are handled weirdly by Prisma, though unique can be fine if sparse. Let's not use @unique just in case a shop has 2 products with no barcode and Prisma complains.
  category    String   @default("GERAL") // GERAL | CABELO | BARBA | SKINCARE
  commissionType  String @default("PERCENTAGE") // PERCENTAGE | FIXED
  commissionValue Float  @default(10)
  active      Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  barbershopId String
  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  sales        ProductSale[]
}

model ProductSale {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  unitPrice Float
  total     Float
  createdAt DateTime @default(now())

  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  barberId     String?
  barber       Barber?    @relation(fields: [barberId], references: [id])
  clientId     String?
  client       User?      @relation("ClientProductSales", fields: [clientId], references: [id])

  @@index([barbershopId, createdAt])
}

model CommissionPayment {
  id     String   @id @default(cuid())
  month  String // "2026-05"
  amount Float
  type   String   @default("STANDARD") // STANDARD | SUBSCRIPTION
  paidAt DateTime @default(now())
  notes  String?

  barberId     String
  barber       Barber     @relation(fields: [barberId], references: [id])
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  @@unique([barberId, month, type])
}

model CommissionVale {
  id          String   @id @default(cuid())
  month       String // "2026-05"
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  barberId     String
  barber       Barber     @relation(fields: [barberId], references: [id])
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
}

model Meta {
  id        String   @id @default(cuid())
  titulo    String
  tipo      String // ATENDIMENTOS | RECEITA | ASSINANTES | OCUPACAO
  periodo   String   @default("MONTHLY") // MONTHLY | WEEKLY
  valorAlvo Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])

  barberId String?
  barber   Barber? @relation(fields: [barberId], references: [id])
}

model ScheduleBlock {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  reason    String?

  barberId String
  barber   Barber @relation(fields: [barberId], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO | DOING | DONE
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id])
  barberId     String?
  barber       Barber?    @relation(fields: [barberId], references: [id])
}

model WhatsAppContact {
  id          String   @id @default(cuid())
  remoteJid   String
  phone       String?
  pushName    String?
  isBlocked   Boolean  @default(false)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  instanceId String?
  instance   WhatsAppInstance? @relation(fields: [instanceId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  messages WhatsAppMessage[]

  @@unique([remoteJid, barbershopId])
  @@index([phone])
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  evolutionId String   @unique
  fromMe      Boolean
  messageType String
  textContent String?
  rawPayload  Json
  timestamp   DateTime
  createdAt   DateTime @default(now())

  contactId String
  contact   WhatsAppContact @relation(fields: [contactId], references: [id])

  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  instanceId String?
  instance   WhatsAppInstance? @relation(fields: [instanceId], references: [id])

  @@index([contactId, timestamp])
  @@index([timestamp])
  @@index([barbershopId, timestamp])
}

model WhatsAppSession {
  id            String   @id @default(cuid())
  phoneNumber   String
  state         String   @default("IDLE") // IDLE, SELECTING_DATE, SELECTING_TIME, SELECTING_BARBER, SELECTING_SERVICE, CONFIRMING
  data          Json?    // Dados temporários (date, serviceId, barberId, etc)
  updatedAt     DateTime @updatedAt
  
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([phoneNumber, barbershopId])
}

model Review {
  id            String      @id @default(cuid())
  rating        Int         // Nota de 0 a 10 (NPS)
  comment       String?
  createdAt     DateTime    @default(now())

  clientId      String
  client        User        @relation("ClientReviews", fields: [clientId], references: [id])
  barbershopId  String
  barbershop    Barbershop  @relation(fields: [barbershopId], references: [id])
  barberId      String?
  barber        Barber?     @relation(fields: [barberId], references: [id])
  appointmentId String?     @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([barbershopId, createdAt])
}

model LoyaltyPoint {
  id            String      @id @default(cuid())
  points        Int
  action        String      // "EARNED" | "REDEEMED"
  description   String?
  createdAt     DateTime    @default(now())

  clientId      String
  client        User        @relation("ClientLoyaltyPoints", fields: [clientId], references: [id])
  barbershopId  String
  barbershop    Barbershop  @relation(fields: [barbershopId], references: [id])
}

model ApiKey {
  id           String     @id @default(cuid())
  keyHash      String     @unique
  keyPrefix    String
  name         String
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime   @default(now())

  @@index([barbershopId])
  @@index([keyHash])
}

// ===================== GATEWAY DE PAGAMENTO POR BARBEARIA =====================

/**
 * PaymentGatewayConfig — Credenciais do gateway de pagamento de cada barbearia.
 *
 * Cada barbearia pode conectar sua própria conta (ex: Mercado Pago) para
 * cobrar clientes diretamente. A plataforma não intermedia nem recebe nada.
 *
 * accessToken é SEMPRE armazenado criptografado (AES-256-GCM via encrypt.ts).
 * NUNCA retornar accessToken em respostas de API.
 *
 * gateway extensível: hoje "mercadopago", futuramente "pagseguro", "stripe", etc.
 */
model PaymentGatewayConfig {
  id           String     @id @default(cuid())
  barbershopId String     @unique
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  gateway      String     @default("mercadopago") // extensível no futuro
  accessToken  String     // 🔒 AES-256-GCM encrypted — NUNCA expor em API
  publicKey    String?    // chave pública MP (segura de exibir no frontend)
  mpUserId     String?    // ID do usuário MP (retornado ao validar o token)
  mpEmail      String?    // e-mail da conta MP conectada (exibido na UI, não sensível)

  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([barbershopId])
}

// ===================== AUDITORIA (H-2) ========================

/**
 * AuditLog — Registro imutável de ações sensíveis realizadas por OWNER/BARBER.
 * Nunca é atualizado; apenas criado (append-only).
 * Ações rastreadas: agendamentos, assinaturas, planos, barbeiros, clientes.
 */
model AuditLog {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  userId       String?    // null para ações via API key
  userEmail    String?
  userRole     String?
  action       String     // CREATE | UPDATE | DELETE | CANCEL | STATUS_CHANGE | BLOCK | UNBLOCK | DEACTIVATE | ACTIVATE
  entity       String     // Appointment | Subscription | Plan | Barber | Client
  entityId     String
  diff         Json?      // { before: {...}, after: {...} } — campos relevantes antes/depois
  ip           String?
  createdAt    DateTime   @default(now())

  @@index([barbershopId, createdAt])
  @@index([entity, entityId])
  @@index([userId])
}

// ===================== MÓDULO FINANCEIRO =====================

model Expense {
  id            String   @id @default(cuid())
  name          String
  description   String?
  amount        Float
  category      String   @default("OUTROS")
  // ESTRUTURA | UTILIDADES | PESSOAS | PRODUTOS | MARKETING | EQUIPAMENTOS | TAXAS | OUTROS
  type          String   @default("FIXED")
  // FIXED (recorrente mensal) | VARIABLE (avulsa) | EXTRAORDINARY (extra)
  isRecurring   Boolean  @default(false)
  dueDay        Int?     // dia do vencimento para recorrentes (1-31)
  paymentMethod String?  @default("PIX")
  // PIX | CASH | CREDIT | DEBIT | BOLETO
  status        String   @default("PENDING")
  // PENDING | PAID | OVERDUE
  month         String   // "2026-05" — mês de competência
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id])

  @@index([barbershopId, month])
  @@index([barbershopId, status])
}

model CashFlowSession {
  id             String    @id @default(cuid())
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
  openingBalance Float     @default(0)
  closingBalance Float?
  status         String    @default("OPEN") // OPEN | CLOSED
  notes          String?
  createdAt      DateTime  @default(now())

  barbershopId   String
  barbershop     Barbershop       @relation(fields: [barbershopId], references: [id])
  entries        CashFlowEntry[]

  @@index([barbershopId, status])
}

model CashFlowEntry {
  id            String          @id @default(cuid())
  type          String          // INCOME | EXPENSE
  description   String
  amount        Float
  category      String          @default("MANUAL")
  paymentMethod String?         @default("CASH")
  createdAt     DateTime        @default(now())

  sessionId     String
  session       CashFlowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ===================== RETENÇÃO DE CLIENTES =====================

model ClientRetention {
  id           String     @id @default(cuid())
  lastSentAt   DateTime   @default(now())

  clientId     String
  client       User       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([clientId, barbershopId])
  @@index([barbershopId])
}
